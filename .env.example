# Copy this file to .env and fill in values. NEVER commit .env.

# ---- W&B ----
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=your_wandb_entity
WANDB_PROJECT=meta-cxr

# ---- GCP ----
GCP_PROJECT_ID=mimic-cxr-jpg-491409
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCS_BUCKET=mimic-cxr-jpg-data

# VM
VM_NAME=meta-cxr-train
VM_MACHINE_TYPE=n1-standard-8
VM_GPU_TYPE=nvidia-tesla-t4
VM_GPU_COUNT=2
VM_DISK_SIZE_GB=200
VM_IMAGE_FAMILY=common-cu121-debian-11
VM_IMAGE_PROJECT=deeplearning-platform-release

# Artifact Registry
ARTIFACT_REPO=meta-cxr
DOCKER_IMAGE=meta-cxr-gcp
DOCKER_TAG=latest

# Service account (created by 01_setup_gcp.sh)
SERVICE_ACCOUNT_NAME=meta-cxr-training
SERVICE_ACCOUNT_EMAIL=meta-cxr-training@mimic-cxr-jpg-491409.iam.gserviceaccount.com

# Run identifier (auto-set in scripts if empty)
RUN_ID=
